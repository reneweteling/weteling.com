    #aurora-cursor.absolute.inset-0 style="background: radial-gradient(560px circle at 55% 35%, rgba(37,99,235,0.16), transparent 70%); will-change: background;"
    .aurora-blob.animate-aurora-drift.absolute.rounded-full style="width:26rem; height:26rem; top:-8rem; left:8%; background: radial-gradient(closest-side, rgba(37,99,235,0.16), transparent); filter: blur(40px);"
