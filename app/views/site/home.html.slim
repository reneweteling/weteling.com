/ Hero aurora + service card hover (inline so they work without a Tailwind/webpacker rebuild)
css:
  @keyframes aurora-drift {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    33%      { transform: translate3d(4%, -6%, 0) scale(1.08); }
    66%      { transform: translate3d(-5%, 4%, 0) scale(0.95); }
  }
  .animate-aurora-drift { animation: aurora-drift 18s ease-in-out infinite; }

  /* Wrapper carries the AOS scroll-reveal so it never fights the card's own
     hover transform/transition (AOS sets its own duration/delay on its target). */
  .svc-grid-item { display: flex; }
  .svc-grid-item > .svc-card { flex: 1 1 auto; }

  /* Service card: smooth lift + subtle tilt toward the cursor + elevated shadow */
  .svc-card {
    position: relative;
    overflow: hidden;
    transform: perspective(1000px);
    transform-style: preserve-3d;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }
  .svc-card:hover {
    transform: perspective(1000px) translateY(-6px);
    box-shadow: 0 22px 48px -12px rgba(2, 6, 23, 0.30);
  }

  /* Cursor-tracking spotlight inside each card */
  .svc-spot {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 300ms ease;
    pointer-events: none;
    background: radial-gradient(280px circle at var(--mx, 50%) var(--my, 50%), rgba(37, 99, 235, 0.10), transparent 70%);
  }
  .svc-spot-light {
    background: radial-gradient(280px circle at var(--mx, 50%) var(--my, 50%), rgba(255, 255, 255, 0.10), transparent 70%);
  }
  .svc-card:hover .svc-spot { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .svc-card { transition: none; }
    .svc-card:hover { transform: none; }
    .svc-spot { display: none; }
    .animate-aurora-drift { animation: none; }
    #hero-aurora { display: none; }
  }

javascript:
  (function () {
    var mq = window.matchMedia;
    var reduce = mq && mq('(prefers-reduced-motion: reduce)').matches;
    var fine = mq && mq('(hover: hover) and (pointer: fine)').matches;

    /* Card spotlight: update --mx/--my per card (one delegated handler). Cheap enough to keep on touch too, but skip if reduced motion. */
    if (!reduce) {
      var cards = document.querySelectorAll('.svc-card');
      for (var i = 0; i < cards.length; i++) {
        (function (card) {
          var maxTilt = parseFloat(card.getAttribute('data-tilt')) || 6; // degrees, per-card override
          card.addEventListener('pointermove', function (e) {
            var r = card.getBoundingClientRect();
            var lx = e.clientX - r.left;
            var ly = e.clientY - r.top;
            card.style.setProperty('--mx', lx + 'px');
            card.style.setProperty('--my', ly + 'px');
            if (fine) {
              var px = lx / r.width - 0.5;   // -0.5 .. 0.5
              var py = ly / r.height - 0.5;
              var rotX = (-py * 2 * maxTilt).toFixed(2); // tilt toward cursor
              var rotY = (px * 2 * maxTilt).toFixed(2);
              card.style.transform = 'perspective(1000px) rotateX(' + rotX + 'deg) rotateY(' + rotY + 'deg) translateY(-6px)';
            }
          });
          card.addEventListener('pointerleave', function () {
            card.style.transform = '';
          });
        })(cards[i]);
      }
    }

    /* Hero cursor glow: lerp toward target to emulate the reference spring (stiffness 45, damping 18). */
    if (reduce || !fine) return;
    var hero = document.getElementById('home');
    var cursor = document.getElementById('aurora-cursor');
    if (!hero || !cursor) return;

    var tx = 55, ty = 35, cx = 55, cy = 35;   // percentages
    var raf = null;
    function onMove(e) {
      var r = hero.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width) * 100;
      ty = ((e.clientY - r.top) / r.height) * 100;
      if (!raf) raf = requestAnimationFrame(tick);
    }
    function tick() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;
      cursor.style.background = 'radial-gradient(560px circle at ' + cx.toFixed(2) + '% ' + cy.toFixed(2) + '%, rgba(37,99,235,0.16), transparent 70%)';
      if (Math.abs(tx - cx) > 0.05 || Math.abs(ty - cy) > 0.05) {
        raf = requestAnimationFrame(tick);
      } else {
        raf = null;
      }
    }
    hero.addEventListener('mousemove', onMove);
  })();

  /* Matrix-style code rain in the hero. Self-contained so it runs independently of
     the cursor-glow gating above. Skipped under prefers-reduced-motion; paused when
     the hero scrolls out of view (IntersectionObserver); throttled to ~24fps. */
  (function () {
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var canvas = document.getElementById('hero-rain');
    var hero = document.getElementById('home');
    if (!canvas || !hero || !canvas.getContext) return;
    var ctx = canvas.getContext('2d');

    var GLYPHS = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ{}[]<>/;=$+*!&|'.split('');
    var FONT = 15;            // glyph size in css px
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var cols = 0, drops = [], speeds = [];
    var cssW = 0, cssH = 0;

    function rand(a, b) { return a + Math.random() * (b - a); }

    function resize() {
      var r = hero.getBoundingClientRect();
      cssW = r.width; cssH = r.height;
      canvas.width = Math.floor(cssW * dpr);
      canvas.height = Math.floor(cssH * dpr);
      canvas.style.width = cssW + 'px';
      canvas.style.height = cssH + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = FONT + 'px "Courier New", ui-monospace, monospace';
      ctx.textBaseline = 'top';
      cols = Math.ceil(cssW / FONT);
      drops = new Array(cols);
      speeds = new Array(cols);
      for (var i = 0; i < cols; i++) {
        drops[i] = Math.floor(rand(-40, 0));   // start above the top, staggered
        speeds[i] = rand(0.4, 1.0);            // rows advanced per frame
      }
    }

    function frame() {
      // translucent black wash for the fading trail
      ctx.fillStyle = 'rgba(3, 7, 18, 0.10)';
      ctx.fillRect(0, 0, cssW, cssH);

      for (var i = 0; i < cols; i++) {
        var x = i * FONT;
        var y = drops[i] * FONT;
        if (y > 0) {
          var g = GLYPHS[(Math.random() * GLYPHS.length) | 0];
          // leading glyph brighter cyan, trail in brand blue
          ctx.fillStyle = 'rgba(186, 230, 253, 0.85)';   // sky-200 head
          ctx.fillText(g, x, y);
          ctx.fillStyle = 'rgba(56, 189, 248, 0.55)';    // sky-400 just behind
          ctx.fillText(GLYPHS[(Math.random() * GLYPHS.length) | 0], x, y - FONT);
        }
        drops[i] += speeds[i];
        // recycle the column once it falls past the bottom (randomised so it doesn't sync)
        if (y > cssH && Math.random() > 0.975) {
          drops[i] = Math.floor(rand(-30, -2));
          speeds[i] = rand(0.4, 1.0);
        }
      }
    }

    var running = false, last = 0, raf = null;
    var INTERVAL = 1000 / 24;   // ~24fps throttle
    function loop(now) {
      if (!running) { raf = null; return; }
      raf = requestAnimationFrame(loop);
      if (now - last < INTERVAL) return;
      last = now;
      frame();
    }
    function start() {
      if (running) return;
      running = true;
      last = 0;
      raf = requestAnimationFrame(loop);
    }
    function stop() {
      running = false;
      if (raf) { cancelAnimationFrame(raf); raf = null; }
    }

    resize();
    var rt = null;
    window.addEventListener('resize', function () {
      clearTimeout(rt);
      rt = setTimeout(resize, 150);
    });

    // Pause when the hero is off-screen to save CPU.
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) start(); else stop();
      }, { threshold: 0 });
      io.observe(hero);
    } else {
      start();
    }
    // Also pause when the tab is hidden.
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stop(); else if (hero.getBoundingClientRect().bottom > 0) start();
    });
  })();
