/ Projects Section (Timeline)
section.py-20.bg-gray-50
  a.anchor#projects
  .max-w-6xl.mx-auto.px-4.sm:px-6.lg:px-8
    .text-center.mb-16 data-aos="fade-up"
      h2.text-3xl.md:text-4xl.font-bold.mb-4 = t('.projects.title')
      p.text-lg.text-gray-600 = t('.projects.subtitle')

    / Timeline - two columns with CSS center line
    #projects-timeline
      ruby:
        left_projects = @projects.each_with_index.select { |_, i| i.even? }.map(&:first)
        right_projects = @projects.each_with_index.select { |_, i| i.odd? }.map(&:first)
        max_rows = [left_projects.size, right_projects.size].max
        shown_years = []

      .timeline-grid.grid.grid-cols-1.md:grid.gap-y-4
        - max_rows.times do |row|
          - lp = left_projects[row]
          - rp = right_projects[row]
          - visible_index = row * 2
          - row_year = lp&.start_date&.year
          - show_year = row_year && !shown_years.include?(row_year)
          - shown_years << row_year if show_year
          / Year marker
          - if show_year
            .md:col-span-2.flex.justify-center.py-1.relative.z-10 class=(visible_index >= 5 ? "timeline-hidden hidden" : "")
              span.inline-block.bg-gray-900.text-white.text-xs.font-bold.px-3.rounded-full class="py-0.5" = row_year

          / Left card
          .timeline-card-left data-aos="fade-up" class=(visible_index >= 5 ? "timeline-hidden hidden" : "")
            - if lp
              = link_to project_path(lp), class: "block group" do
                .svc-card.bg-white.rounded-xl.shadow-sm.p-5 data-tilt="4"
                  .svc-spot
                  .flex.items-start.gap-3
                    - if lp.image.present?
                      .flex-shrink-0
                        = image_tag lp.image.medium.url, class: "w-16 h-16 rounded-lg object-contain", loading: :lazy
                    div
                      h3.text-base.font-bold.text-gray-900.group-hover:text-blue-600.transition-colors = lp.title
                      p.text-sm.text-gray-500.mb-1 = lp.subtitle
                      .text-xs.text-gray-400.mb-2
                        = l lp.start_date
                        |  —
                        - if lp.end_date.present?
                          = l lp.end_date
                        - else
                          = t('site.cv.present-date')
                      .flex.flex-wrap.gap-2.mt-1
                        - lp.tags.first(4).each do |tag|
                          span.inline-block.bg-blue-50.text-blue-700.text-xs.px-2.rounded class="py-0.5" = tag
                        - if lp.tags.size > 4
                          span.inline-block.text-gray-400.text-xs = '+' + (lp.tags.size - 4).to_s

          / Right card (offset down for staggered look)
          .timeline-card-right.md:mt-12 data-aos="fade-up" data-aos-delay="100" class=((visible_index + 1) >= 5 ? "timeline-hidden hidden" : "")
            - if rp
              = link_to project_path(rp), class: "block group" do
                .svc-card.bg-white.rounded-xl.shadow-sm.p-5 data-tilt="4"
                  .svc-spot
                  .flex.items-start.gap-3
                    - if rp.image.present?
                      .flex-shrink-0
                        = image_tag rp.image.medium.url, class: "w-16 h-16 rounded-lg object-contain", loading: :lazy
                    div
                      h3.text-base.font-bold.text-gray-900.group-hover:text-blue-600.transition-colors = rp.title
                      p.text-sm.text-gray-500.mb-1 = rp.subtitle
                      .text-xs.text-gray-400.mb-2
                        = l rp.start_date
                        |  —
                        - if rp.end_date.present?
                          = l rp.end_date
                        - else
                          = t('site.cv.present-date')
                      .flex.flex-wrap.gap-2.mt-1
                        - rp.tags.first(4).each do |tag|
                          span.inline-block.bg-blue-50.text-blue-700.text-xs.px-2.rounded class="py-0.5" = tag
                        - if rp.tags.size > 4
                          span.inline-block.text-gray-400.text-xs = '+' + (rp.tags.size - 4).to_s

    / Show more button
    - if @projects.size > 5
      .flex.justify-center.mt-8.relative.z-10
        button#timeline-toggle.inline-flex.items-center.gap-2.border.border-gray-300.bg-gray-50.text-gray-700.px-6.py-3.rounded-lg.hover:bg-gray-100.transition-colors.font-medium
          span = t('.projects.show_more')
          span ↓

