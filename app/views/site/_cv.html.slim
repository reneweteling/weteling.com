ruby:
  content = I18n.locale.to_s == 'nl' ? Page.cv.first.content_nl : Page.cv.first.content_en

- projects = capture do
  .projects.not-prose
    = render partial: 'project', collection: Project.for_cv, locals: { as_cv: true }

.cv.prose.prose-lg.max-w-none.prose-li:my-0.prose-ul:my-1.prose-ol:my-1.prose-p:my-2.prose-h2:mt-8.prose-h2:mb-3.prose-h3:mt-6.prose-h3:mb-2.prose-h4:mt-3.prose-h4:mb-1
  == markdown content.gsub('[[projects]]', projects)


sass:
  .cv
    color: black
    background-color: white

    a
      color: #2563eb
      text-decoration: underline
      text-decoration-color: #93c5fd
      &:hover
        color: #1d4ed8

    .personal-info + ul
      list-style: none
      padding-left: 0
      margin-top: 0.5rem
      margin-bottom: 0.5rem
      li
        padding-left: 0
        margin-top: 0 !important
        margin-bottom: 0 !important
        line-height: 1.6
        &::before
          display: none
        > strong
          display: inline-block
          width: 200px

    .projects
      margin-top: 1rem
      font-size: 0
      .project
        display: inline-block
        vertical-align: top
        width: 50%
        page-break-inside: avoid
        padding: 0.75rem 1rem 0.75rem 0
        font-size: 0.875rem
        position: relative
        &:nth-child(even)
          padding-left: 1rem
          padding-right: 0
        h4
          font-weight: 700
          font-size: 1rem
          margin-bottom: 0.15rem
        .subtitle
          color: #6b7280
          font-size: 0.8rem
        .start, .end
          font-size: 0.75rem
          color: #9ca3af
        p
          margin-bottom: 0.25rem
        .description
          margin-top: 0.25rem
          font-size: 0.75rem
          line-height: 1.4
          color: #374151
        .no-flex-col-2
          position: absolute
          top: 0.75rem
          right: 1rem
          width: 110px
          height: 60px
          display: flex
          align-items: center
          justify-content: flex-end
          .img-fluid
            max-width: 110px
            max-height: 60px
            object-fit: contain

    @media (max-width: 640px)
      .personal-info + ul
        li
          > strong
            display: block
            width: auto
            margin-bottom: 0.25rem

      .projects .project
        width: 100%
        padding-left: 0 !important
